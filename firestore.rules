rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId}/votes/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['ratings', 'mom', 'fixtureId', 'updatedAt'])
        && request.resource.data.fixtureId == matchId
        && request.resource.data.mom is string
        && request.resource.data.mom.size() <= 80
        && request.resource.data.ratings is map
        && request.resource.data.ratings.size() <= 35;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
