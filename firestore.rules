rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId}/votes/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['ratings', 'mom', 'fixtureId', 'updatedAt'])
        && request.resource.data.fixtureId == matchId
        && request.resource.data.mom is string
        && request.resource.data.mom.size() <= 80
        && request.resource.data.ratings is map
        && request.resource.data.ratings.size() <= 35;
      allow delete: if false;
    }

    match /seasons/{seasonId}/predictions/{predictionId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'nickname', 'fixtureId', 'fixtureDate', 'competition', 'opponent', 'arsenalScore', 'opponentScore', 'comment', 'submittedAt'])
        && request.resource.data.nickname is string
        && request.resource.data.nickname.size() > 0
        && request.resource.data.nickname.size() <= 20
        && request.resource.data.comment is string
        && request.resource.data.comment.size() <= 120
        && request.resource.data.arsenalScore is int
        && request.resource.data.arsenalScore >= 0
        && request.resource.data.arsenalScore <= 15
        && request.resource.data.opponentScore is int
        && request.resource.data.opponentScore >= 0
        && request.resource.data.opponentScore <= 15;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
